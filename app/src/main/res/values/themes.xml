<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.HabitTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/purple_200</item>
        <item name="colorOnPrimaryContainer">@color/purple_700</item>
        <item name="colorSecondary">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/teal_200</item>
        <item name="colorOnSecondaryContainer">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- 0. Purple（默认） -->
    <style name="Theme.HabitTracker.Purple" parent="Theme.HabitTracker" />

    <!-- 1. Blue -->
    <style name="Theme.HabitTracker.Blue" parent="Theme.HabitTracker">
        <item name="colorPrimary">#006493</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#C6E6FF</item>
        <item name="colorOnPrimaryContainer">#001E31</item>
    </style>

    <!-- 2. Teal -->
    <style name="Theme.HabitTracker.Teal" parent="Theme.HabitTracker">
        <item name="colorPrimary">#006C4C</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#B8EBD0</item>
        <item name="colorOnPrimaryContainer">#002116</item>
    </style>

    <!-- 3. Green -->
    <style name="Theme.HabitTracker.Green" parent="Theme.HabitTracker">
        <item name="colorPrimary">#386A20</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#C8E6BB</item>
        <item name="colorOnPrimaryContainer">#092100</item>
    </style>

    <!-- 4. Orange -->
    <style name="Theme.HabitTracker.Orange" parent="Theme.HabitTracker">
        <item name="colorPrimary">#8D5000</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#FFDCC2</item>
        <item name="colorOnPrimaryContainer">#2E1600</item>
    </style>

    <!-- 5. Red -->
    <style name="Theme.HabitTracker.Red" parent="Theme.HabitTracker">
        <item name="colorPrimary">#B3261E</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#FFDAD6</item>
        <item name="colorOnPrimaryContainer">#410002</item>
    </style>

    <!-- 6. Pink -->
    <style name="Theme.HabitTracker.Pink" parent="Theme.HabitTracker">
        <item name="colorPrimary">#7D5260</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#FFD8E4</item>
        <item name="colorOnPrimaryContainer">#31101B</item>
    </style>

    <!-- 7. Navy -->
    <style name="Theme.HabitTracker.Navy" parent="Theme.HabitTracker">
        <item name="colorPrimary">#00497A</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#CDE5FF</item>
        <item name="colorOnPrimaryContainer">#00152B</item>
    </style>

    <!-- 8. Grey -->
    <style name="Theme.HabitTracker.Grey" parent="Theme.HabitTracker">
        <item name="colorPrimary">#5F5F5F</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#E0E0E0</item>
        <item name="colorOnPrimaryContainer">#1C1C1C</item>
    </style>

    <!-- 粗体文字叠加 -->
    <style name="TextAppearanceOverlay_Bold">
        <item name="textAppearanceBodyLarge">@style/Bold.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/Bold.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/Bold.BodySmall</item>
        <item name="textAppearanceTitleMedium">@style/Bold.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/Bold.TitleSmall</item>
    </style>

    <style name="Bold.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Bold.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Bold.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Bold.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Bold.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textStyle">bold</item>
    </style>
</resources>
